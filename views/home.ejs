<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login Successful</title>

    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:Arial, sans-serif;
        }

        body{
            height:100vh;
            display:flex;
            justify-content:center;
            align-items:center;
            background:#f0f2f5;
        }

        .container{
            background:white;
            padding:40px;
            width:350px;
            text-align:center;
            border-radius:12px;
            box-shadow:0 0 15px rgba(0,0,0,0.1);
        }

        h1{
            color:#28a745;
            margin-bottom:15px;
        }

        p{
            color:#555;
            margin-bottom:25px;
        }

        a{
            text-decoration:none;
            background:#007bff;
            color:white;
            padding:10px 20px;
            border-radius:6px;
            display:inline-block;
        }

        a:hover{
            background:#0056b3;
        }

        .check{
            font-size:60px;
            color:#28a745;
            margin-bottom:20px;
        }
    </style>
</head>
<body>

    <div class="container">

        <div class="check">✔</div>

        <h1>Login Successful</h1>

        <p>Welcome back! You have logged in successfully.</p>

        <a href="/">Go Back</a>

    </div>

</body>
</html>